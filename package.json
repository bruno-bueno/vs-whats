{
  "name": "whatsapp-bot-vscode",
  "displayName": "Code Notifier",
  "description": "Integração de notificações em tempo real no VS Code",
  "version": "1.0.12",
  "publisher": "meubot",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "whatsapp.chatView",
          "name": "Notificações"
        }
      ]
    },
    "commands": [
      {
        "command": "whatsappbot.start",
        "title": "Notifier: Iniciar"
      },
      {
        "command": "whatsappbot.stop",
        "title": "Notifier: Parar"
      }
    ]
  },
  "dependencies": {
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
