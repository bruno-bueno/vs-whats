{
  "name": "whatsapp-bot-vscode",
  "displayName": "WhatsApp",
  "description": "WhatsApp Bot no Sidebar do VS Code",
  "version": "1.0.9",
  "publisher": "meubot",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "whatsapp.chatView",
          "name": "WhatsApp"
        }
      ]
    },
    "commands": [
      {
        "command": "whatsappbot.start",
        "title": "WhatsApp: Iniciar Bot"
      },
      {
        "command": "whatsappbot.stop",
        "title": "WhatsApp: Parar Bot"
      }
    ]
  },
  "dependencies": {
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
